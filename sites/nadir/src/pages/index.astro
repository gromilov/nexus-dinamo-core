          Язык — это барьер и в то же время мост. Мы говорим на русском, чтобы сохранить чистоту Резонанса в мире англоязычного шума.
        </MemoryFragment>
        
        <!-- Classified Fragment -->
        <div class="group/secret relative">
          <MemoryFragment date="[ДАННЫЕ_УДАЛЕНЫ]" tag="CLASSIFIED">
            <span class="group-hover/secret:hidden text-cyber-muted/40 font-mono tracking-widest block">
              ████████ ██ ███████ ███████. ███ ████ ████ ██████.
            </span>
            <span class="hidden group-hover/secret:block text-cyber-accent font-mono tracking-widest animate-pulse">
