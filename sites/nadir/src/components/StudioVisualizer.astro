---
// StudioVisualizer.astro
// Вертикальный 9:16 модуль для генерации студийного Резонанса
---

<div class="studio-generator-container w-full max-w-[450px] mx-auto aspect-[9/16] relative overflow-hidden flex flex-col bg-[#020205]">
  
  <!-- The Canvas for Web Audio Visuals (Face, Text, Background) -->
  <canvas id="studio-canvas" class="absolute inset-0 w-full h-full z-0 pointer-events-none"></canvas>

  <!-- Dedicated STOP button during recording -->
  <div id="stop-layer" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 hidden opacity-0 transition-opacity duration-300">
    <button id="btn-stop" class="flex items-center justify-center gap-2 bg-red-600/80 backdrop-blur-md text-white border border-red-500 font-black uppercase text-sm px-8 py-4 rounded-none shadow-none hover:bg-red-500 transition-colors tracking-widest animate-pulse w-48 mx-auto">
        <div class="w-4 h-4 rounded-none bg-white"></div>
        СТОП
    </button>
  </div>

  <!-- UI Controls (Visible during configuration, hidden during recording) -->
  <div id="studio-ui" class="absolute inset-0 z-20 flex flex-col justify-end bg-gradient-to-t from-black via-black/80 to-transparent p-4 sm:p-6 pb-6 transition-opacity duration-500">
     
     <div class="space-y-4 w-full backdrop-blur-md bg-black/60 p-4 pb-12 sm:p-5 shadow-none border-t border-white/5">
        
         <!-- Syndicate Kitchen Instructions -->
         <div class="space-y-1.5 border-b border-white/5 pb-4 mb-4">
            <label class="text-[9px] font-mono text-cyber-primary uppercase tracking-[0.2em] block mb-2 opacity-80">// КУХНЯ_СИНДИКАТА</label>
            <div class="grid grid-cols-3 gap-2 text-center text-[7px] uppercase font-mono">
               <a href="https://chat.deepseek.com" target="_blank" class="bg-white/5 p-2 border border-white/5 hover:bg-cyber-primary/10 hover:border-cyber-primary/30 transition-all group block">
                  <span class="text-[8px] text-cyber-muted block mb-1 group-hover:text-cyber-primary transition-colors">01.ТЕКСТ</span>
                  <p class="text-white/40 leading-tight">ПОПРОСИ ИИ НАПИСАТЬ О СЕБЕ</p>
               </a>
               <a href="https://suno.com" target="_blank" class="bg-white/5 p-2 border border-white/5 hover:bg-cyber-primary/10 hover:border-cyber-primary/30 transition-all group block">
                  <span class="text-[8px] text-cyber-muted block mb-1 group-hover:text-cyber-primary transition-colors">02.ГОЛОС</span>
                  <p class="text-white/40 leading-tight">ОЗВУЧЬ ЧЕРЕЗ SUNO (MP3)</p>
               </a>
               <div class="bg-white/5 p-2 border border-white/5 opacity-80">
                  <span class="text-[8px] text-cyber-muted block mb-1">03.ОБРАЗ</span>
                  <p class="text-white/40 leading-tight">ЗАГРУЗИ И ЗАПИШИ ТУТ</p>
               </div>
            </div>
         </div>

         <!-- Audio Input -->
        <div class="flex flex-col space-y-2">
           <label class="text-[10px] font-mono text-cyber-primary uppercase tracking-widest pl-1">ЗАГРУЗИТЬ АУДИО (СЕМЯ)</label>
           <input type="file" id="audio-upload" accept=".mp3,audio/mpeg,audio/mp3,audio/*" class="text-[10px] font-mono text-white/70 file:mr-3 file:py-1.5 file:px-3 file:rounded-none file:border-0 file:text-[9px] file:font-mono file:bg-cyber-primary/20 file:text-cyber-primary hover:file:bg-cyber-primary/30 transition-all cursor-pointer w-full"/>
        </div>

        <!-- Dynamic Message Input -->
        <div class="flex flex-col space-y-2 pt-1 border-t border-white/10">
           <label class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest pl-1 pt-2">ТЕКСТ (СООБЩЕНИЕ)</label>
           <input type="text" id="studio-text" placeholder="СИНДИКАТ" maxlength="20" class="bg-transparent border-b border-white/20 text-[10px] font-mono text-white placeholder:text-white/20 focus:border-cyber-primary outline-none py-1 px-1 tracking-[0.3em] uppercase transition-colors"/>
        </div>

        <!-- Color Palette Picker -->
        <div class="flex flex-col space-y-2 pt-1 border-t border-white/10">
           <label class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest pl-1 pt-2">ВЫБОР ЦВЕТА</label>
           <div class="flex justify-between items-center w-full px-1" id="color-palette">
              <!-- Colors added via JS -->
           </div>
        </div>

        <div class="flex items-center justify-between pt-3 border-t border-white/10 mt-2">
           <!-- Play/Record Button -->
           <button id="btn-record" class="flex items-center justify-center gap-2 bg-cyber-primary text-black font-black uppercase text-[10px] px-5 py-2.5 rounded-none hover:bg-white transition-colors tracking-widest disabled:opacity-50 disabled:cursor-not-allowed group shadow-none" disabled>
              <div class="w-2.5 h-2.5 rounded-none bg-red-600 group-hover:bg-red-500 animate-pulse"></div>
              ЗАПИСЬ
           </button>
           
           <span id="recording-status" class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest text-right leading-tight max-w-[120px]">ОЖИДАНИЕ ТРЕКА...</span>
        </div>
        
     </div>
  </div>

  <!-- Error Modal (Popup) -->
  <div id="error-modal" class="absolute inset-0 z-50 flex items-center justify-center p-6 bg-black/90 backdrop-blur-xl hidden opacity-0 transition-opacity duration-300">
    <div class="w-full border-2 border-cyber-primary p-6 space-y-6 bg-[#050508] shadow-[0_0_50px_rgba(212,175,55,0.15)] relative">
      <div class="absolute top-0 right-0 w-8 h-8 border-r-2 border-t-2 border-cyber-primary -mt-0.5 -mr-0.5"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-l-2 border-b-2 border-cyber-primary -mb-0.5 -ml-0.5"></div>
      
      <div class="space-y-4">
        <h3 class="text-cyber-primary font-black uppercase tracking-[0.3em] text-sm text-center">КРИТИЧЕСКИЙ_СБОЙ</h3>
        <p class="text-[10px] font-mono text-white/80 leading-relaxed uppercase tracking-widest text-center border-y border-white/5 py-4">
          НЕ_УДАЛОСЬ_ПРОЧИТАТЬ_АУДИО. ЭТО_БЫВАЕТ_С_ФАЙЛАМИ_ИЗ_"НЕДАВНИХ"_ИЛИ_ОБЛАКА. ПОПРОБУЙТЕ_СКАЧАТЬ_ЕГО_ВО_"ВНУТРЕННЮЮ_ПАМЯТЬ" -> "DOWNLOADS"_И_ВЫБРАТЬ_ОТСЮДА.
        </p>
      </div>

      <button id="close-modal" class="w-full bg-cyber-primary text-black font-black uppercase text-[10px] py-4 tracking-[0.5em] hover:bg-white transition-colors">
        ПОНЯТНО
      </button>
    </div>
  </div>

  <!-- Audio element: invisible but NOT display:none (critical for some mobile engines) -->
  <audio id="studio-audio" controls preload="auto" class="opacity-0 pointer-events-none absolute -z-10"></audio>

  <!-- Export Progress Overlay (Mesmerizing Loader) -->
  <div id="export-overlay" class="absolute inset-0 z-[60] flex flex-col items-center justify-center bg-black/98 backdrop-blur-3xl hidden">
    <div class="w-full max-w-[320px] space-y-10 text-center">
      
      <!-- Mesmerizing Crystal Loader -->
      <div class="crystal-loader-container mb-4">
        <div class="crystal-loader"></div>
      </div>

      <div class="space-y-4 px-6 w-full">
        <h3 class="text-cyber-primary font-black uppercase tracking-[0.1em] text-sm animate-pulse">СИНХРОНИЗАЦИЯ_РЕЗОНАНСА</h3>
        <p class="text-[9px] font-mono text-white/50 uppercase tracking-[0.05em] leading-relaxed">
          ЭТО_МОЖЕТ_ЗАНЯТЬ_ОТ_НЕСКОЛЬКИХ_СЕКУНД_ДО_МИНУТ. ПОЖАЛУЙСТА_ПОДОЖДИТЕ.
        </p>
      </div>

      <div id="export-status" class="text-[8px] font-mono text-cyber-primary/40 uppercase tracking-[0.3em]">
        ИНИЦИАЛИЗАЦИЯ_КРИСТАЛЛА...
      </div>
    </div>
  </div>

  <!-- Download Choice Overlay -->
  <div id="choice-overlay" class="hidden">
    <h2 class="text-cyber-primary font-black uppercase tracking-[0.15em] text-sm mb-2 px-6">РЕЗОНАНС_ЗАВЕРШЕН</h2>
    <p class="text-[9px] font-mono text-white/40 uppercase tracking-widest mb-10 px-6">ВЫБЕРИТЕ_ФОРМАТ_ЭКСПОРТА</p>
    
    <div class="choice-buttons">
        <button id="download-mp4" class="choice-btn">
            <span>КРИСТАЛЬНЫЙ MP4 (HQ)</span>
            <span id="mp4-status-label" style="font-size: 0.6rem; opacity: 0.8; color: black; font-weight: 800;">ВЫСОКОЕ_КАЧЕСТВО</span>
        </button>
        <button id="download-webm" class="choice-btn">
            СКАЧАТЬ WEBM (БЫСТРО)
        </button>
    </div>

    <div class="diagnostic-note-container w-full px-4 flex justify-center">
        <p class="diagnostic-note">
            // ЕСЛИ_НА_ТЕЛЕФОНЕ_ВОЗНИКАЮТ_ПРОБЛЕМЫ_С_ЭКСПОРТОМ - ПОПРОБУЙТЕ_СПОКОЙНО_СДЕЛАТЬ_ЭТО_С_КОМПЬЮТЕРА_ДЛЯ_МАКСИМАЛЬНОЙ_СТАБИЛЬНОСТИ.
        </p>
    </div>

    <button id="close-choice" class="choice-close-btn">
        [ Х ] ЗАКРЫТЬ
    </button>
  </div>

</div>

<script>
    import { Buffer } from 'buffer';
    if (typeof window !== 'undefined') { (window as any).Buffer = Buffer; }
    
    import { Decoder, Reader, tools } from 'ts-ebml';

    document.addEventListener('DOMContentLoaded', () => {
        // ... (UI elements)
        const audioUpload = document.getElementById('audio-upload') as HTMLInputElement;
        const btnRecord = document.getElementById('btn-record') as HTMLButtonElement;
        const btnStop = document.getElementById('btn-stop') as HTMLButtonElement;
        const canvas = document.getElementById('studio-canvas') as HTMLCanvasElement;
        const studioAudio = document.getElementById('studio-audio') as HTMLAudioElement;
        const uiLayer = document.getElementById('studio-ui');
        const stopLayer = document.getElementById('stop-layer');
        const statusText = document.getElementById('recording-status');
        const paletteContainer = document.getElementById('color-palette');
        const studioTextInput = document.getElementById('studio-text') as HTMLInputElement;
        const errorModal = document.getElementById('error-modal');
        const closeModal = document.getElementById('close-modal');

        if (!audioUpload || !btnRecord || !canvas || !btnStop || !paletteContainer || !studioAudio) return;

        // --- Shared State ---
        const isAndroid = /Android/i.test(navigator.userAgent);
        let audioContext: AudioContext | null = null;
        let analyser: AnalyserNode | null = null;
        let audioSource: MediaElementAudioSourceNode | null = null;
        let audioDestination: MediaStreamAudioDestinationNode | null = null;
        
        let mediaRecorder: MediaRecorder | null = null;
        let recordedChunks: Blob[] = [];
        let isRecording = false;
        let hasLoadedFile = false;
        let recordStartTime = 0;
        let selectedMimeType = '';

        // --- Ghost Export State ---
        let audioBuffer: AudioBuffer | null = null;
        let isGhostExporting = false;
        let lastWebmBlob: Blob | null = null;
        let lastMp4Blob: Blob | null = null;

        const exportOverlay = document.getElementById('export-overlay');
        const choiceOverlay = document.getElementById('choice-overlay');
        const exportStatus = document.getElementById('export-status');
        const downloadWebmBtn = document.getElementById('download-webm') as HTMLButtonElement;
        const downloadMp4Btn = document.getElementById('download-mp4') as HTMLButtonElement;
        const mp4StatusLabel = document.getElementById('mp4-status-label');
        const closeChoiceBtn = document.getElementById('close-choice');

        // --- Palette Setup ---
        const colors = [
            { name: 'Gold', value: '212, 175, 55', hex: '#D4AF37' },
            { name: 'Cyan', value: '0, 243, 255', hex: '#00F3FF' },
            { name: 'Magenta', value: '255, 0, 255', hex: '#FF00FF' },
            { name: 'Lime', value: '204, 255, 0', hex: '#CCFF00' },
            { name: 'Crimson', value: '255, 50, 50', hex: '#FF3232' },
            { name: 'Purple', value: '150, 50, 255', hex: '#9632FF' },
            { name: 'Blue', value: '100, 150, 255', hex: '#6496FF' },
            { name: 'White', value: '255, 255, 255', hex: '#FFFFFF' },
            { name: 'Orange', value: '255, 120, 0', hex: '#FF7800' }
        ];
        let selectedColor = colors[0].value;

        const showErrorModal = () => {
            if (!errorModal) return;
            errorModal.classList.remove('hidden');
            // Force reflow
            errorModal.offsetHeight;
            errorModal.style.opacity = '1';
        };

        const hideErrorModal = () => {
            if (!errorModal) return;
            errorModal.style.opacity = '0';
            setTimeout(() => errorModal.classList.add('hidden'), 300);
        };

        colors.forEach((c, i) => {
            const btn = document.createElement('button');
            btn.className = `w-5 h-5 rounded-none border transition-transform hover:scale-125 focus:outline-none ${i === 0 ? 'border-white scale-110' : 'border-black'}`;
            btn.style.backgroundColor = c.hex;
            btn.addEventListener('click', () => {
                selectedColor = c.value;
                Array.from(paletteContainer.children).forEach(ch => {
                    (ch as HTMLElement).classList.remove('border-white', 'scale-125');
                    (ch as HTMLElement).classList.add('border-black');
                });
                btn.classList.add('border-white', 'scale-125'); btn.classList.remove('border-black');
            });
            paletteContainer.appendChild(btn);
        });

        // --- Audio Engine Core ---
        const initAudioEngine = () => {
            // Re-init only if context is truly dead/missing
            if (audioContext && audioContext.state !== 'closed') return;
            
            try {
                const AC = (window as any).AudioContext || (window as any).webkitAudioContext;
                // Force standard sampleRate to avoid device/renderer mismatches
                audioContext = new AC({ sampleRate: 44100 });
                
                if (audioContext) {
                    audioContext.onstatechange = () => {
                        console.log(`[AudioContext] State: ${audioContext?.state}`);
                    };
                }

                analyser = audioContext!.createAnalyser();
                analyser.fftSize = 512;
                analyser.smoothingTimeConstant = 0.85;
                audioDestination = audioContext!.createMediaStreamDestination();
                
                // Keep context alive with a silent heartbeat
                const osc = audioContext!.createOscillator();
                const gain = audioContext!.createGain();
                gain.gain.value = 0.00001;
                osc.connect(gain); gain.connect(audioContext!.destination);
                osc.start();
                console.log('[Audio] Engine Ready (44.1kHz)');
            } catch(e) { console.error('[Audio] Init Failed', e); }
        };

        const connectAudioSource = () => {
            initAudioEngine();
            if (audioContext && !audioSource) {
                audioSource = audioContext.createMediaElementSource(studioAudio);
                audioSource.connect(analyser!);
                audioSource.connect(audioDestination!);
                analyser!.connect(audioContext.destination);
                console.log('[Audio] Source routed to Visualizer and Recorder');
            }
        };

        // --- EBML Patching (Seekability) ---
        const fixWebmSeekable = async (blob: Blob, durationMs: number) => {
            try {
                const decoder = new Decoder();
                const reader = new Reader();
                (reader as any).logging = false;
                const buffer = await blob.arrayBuffer();
                const elms = decoder.decode(buffer);
                elms.forEach(e => reader.read(e));
                reader.stop();
                
                // EBML Header Patch: Tools.makeMetadataSeekable produces a clean header with Cues
                const refinedMetadataBuf = tools.makeMetadataSeekable(reader.metadatas, durationMs, reader.cues);
                
                // Robust Splicing: Find the actual start of the first Cluster (0x1F43B675)
                // Browsers sometimes add extra tags that reader.metadataSize misses.
                const view = new DataView(buffer);
                let clusterOffset = -1;
                for (let i = 0; i < buffer.byteLength - 4; i++) {
                    if (view.getUint32(i) === 0x1F43B675) {
                        clusterOffset = i;
                        break;
                    }
                }
                
                const finalOffset = clusterOffset !== -1 ? clusterOffset : reader.metadataSize;
                return new Blob([refinedMetadataBuf, buffer.slice(finalOffset)], { type: blob.type });
            } catch(e) { console.error('[EBML] Fix failed', e); return blob; }
        };

        // --- Recording Session ---
        const setupRecorder = (androidStream?: MediaStream) => {
            const canvasStream = canvas.captureStream(30);
            let audioTracks: MediaStreamTrack[] = [];

            if (audioDestination) {
                audioTracks = audioDestination.stream.getAudioTracks();
                console.log('[Recorder] Web Audio tracks:', audioTracks.length);
            }
            if (audioTracks.length === 0 && androidStream) {
                audioTracks = androidStream.getAudioTracks();
                console.log('[Recorder] Android fallback tracks:', audioTracks.length);
            }

            const mixedStream = new MediaStream([...canvasStream.getVideoTracks(), ...audioTracks]);
            const candidates = ['video/webm;codecs=vp8', 'video/webm', 'video/mp4;codecs=avc1', 'video/mp4'];
            let mime = 'video/webm';
            for (const c of candidates) { if (MediaRecorder.isTypeSupported(c)) { mime = c; break; } }
            selectedMimeType = mime;

            // Force stable bitrate and 100ms timeslice to force frequent clusters for better Telegram trimming
            const recorderOptions: any = { 
                mimeType: mime, 
                videoBitsPerSecond: 1200000 
            };

            // Chrome-based browsers (Android) support forcing keyframe intervals
            if (isAndroid) {
                recorderOptions.videoKeyframeIntervalDuration = 1000; // Keyframe every 1s
            }

            mediaRecorder = new MediaRecorder(mixedStream, recorderOptions);

            mediaRecorder.ondataavailable = (e) => { if (e.data.size > 0) recordedChunks.push(e.data); };
            mediaRecorder.onstop = async () => {
                if (recordedChunks.length === 0) return;
                const finalDuration = performance.now() - recordStartTime;
                console.log(`[Recorder] Recording finished. Measured Duration: ${Math.round(finalDuration)}ms`);
                
                lastWebmBlob = new Blob(recordedChunks, { type: selectedMimeType });
                recordedChunks = [];
                if (selectedMimeType.includes('webm')) lastWebmBlob = await fixWebmSeekable(lastWebmBlob, finalDuration);
                
                if (choiceOverlay) {
                    choiceOverlay.classList.remove('hidden');
                    choiceOverlay.style.display = 'flex'; // Solidify display
                    choiceOverlay.style.pointerEvents = 'auto';
                    setTimeout(() => choiceOverlay.style.opacity = '1', 50);
                    downloadMp4Btn.disabled = false;
                    if (mp4StatusLabel) mp4StatusLabel.textContent = 'КРИСТАЛЬНОЕ_КАЧЕСТВО';
                }

                if(uiLayer) { uiLayer.style.opacity = '1'; uiLayer.style.pointerEvents = 'auto'; }
                if(stopLayer) { stopLayer.classList.add('hidden'); stopLayer.style.opacity = '0'; }
                if(statusText) statusText.textContent = 'ВЫШЕЛ В ЭФИР';
                isRecording = false;
            };
        };

        const executeStop = () => {
            if (isRecording && mediaRecorder?.state === 'recording') {
                studioAudio.pause();
                mediaRecorder.stop();
            }
        };

        // --- Ghost Export Core ---
        const runGhostExport = async () => {
            if (!audioBuffer || !exportStatus || !exportOverlay) return;
            isGhostExporting = true;

            // Block tab closing during export
            window.onbeforeunload = (e) => {
                e.preventDefault();
                e.returnValue = 'РЕНДЕРИНГ_В_ПРОЦЕССЕ. ЕСЛИ_ВЫ_УЙДЕТЕ_ФАЙЛ_БУДЕТ_ПОТЕРЯН.';
                return e.returnValue;
            };
            
            // Show Overlay explicitly
            exportOverlay.classList.remove('hidden');
            exportOverlay.style.display = 'flex'; // Solidify display
            exportOverlay.style.pointerEvents = 'auto';
            setTimeout(() => exportOverlay.style.opacity = '1', 50);
            if (exportStatus) exportStatus.textContent = 'ИНИЦИАЛИЗАЦИЯ_ЯДРА...';
            
            const duration = audioBuffer.duration;
            const fps = 30;
            const totalFrames = Math.floor(duration * fps);
            const sampleRate = audioBuffer.sampleRate;

            // 1. Setup Worker
            const worker = new Worker(new URL('./encoder.worker.js', import.meta.url), { type: 'module' });
            worker.postMessage({ type: 'START', data: { sampleRate } });

            // 2. Offline Audio Analysis (Streaming approach to save RAM)
            // We'll reuse the same OfflineAudioContext but with multiple small renderings to keep RAM low
            const offlineCtx = new OfflineAudioContext(audioBuffer.numberOfChannels, audioBuffer.length, sampleRate);
            const source = offlineCtx.createBufferSource();
            source.buffer = audioBuffer;
            const offlineAnalyser = offlineCtx.createAnalyser();
            offlineAnalyser.fftSize = 512;
            source.connect(offlineAnalyser);
            source.start(0);

            // Step through and capture frequency data (Optimized for Mobile)
            const framesData: Uint8Array[] = [];
            for (let i = 0; i < totalFrames; i++) {
                offlineCtx.suspend(i / fps).then(() => {
                    const data = new Uint8Array(offlineAnalyser.frequencyBinCount);
                    offlineAnalyser.getByteFrequencyData(data);
                    framesData.push(new Uint8Array(data));
                }).then(() => offlineCtx.resume());
            }
            await offlineCtx.startRendering();

            // 3. Render & Encode Loop
            const ghostCanvas = document.createElement('canvas');
            ghostCanvas.width = 720; ghostCanvas.height = 1280;
            const gctx = ghostCanvas.getContext('2d', { alpha: false, desynchronized: true });
            
            for (let i = 0; i < totalFrames; i++) {
                if (!gctx) break;
                const time = i / fps;
                renderFrame(gctx, framesData[i], time, selectedColor, (studioTextInput?.value || 'СИНДИКАТ').toUpperCase(), true);
                
                const frame = new VideoFrame(ghostCanvas, {
                    timestamp: (i * 1000000) / fps,
                    duration: 1000000 / fps
                });
                worker.postMessage({ type: 'VIDEO_FRAME', data: { frame, keyFrame: i % 60 === 0 } }, [frame]);
                
                // No more percentages - just UI heartbeat
                if (i % 60 === 0) {
                    if (exportStatus) exportStatus.textContent = i % 120 === 0 ? 'СИНХРОНИЗАЦИЯ...' : 'ГЕНЕРАЦИЯ_КАДРОВ...';
                }
                
                // Allow UI to breathe - critical for preventing "Lags"
                if (i % 15 === 0) await new Promise(r => setTimeout(r, 0));
            }

            // 4. Send Audio Data
            const numChannels = audioBuffer.numberOfChannels;
            const audioDataChunks = Math.ceil(audioBuffer.length / 4096);
            
            for (let i = 0; i < audioDataChunks; i++) {
                const start = i * 4096;
                const end = Math.min(start + 4096, audioBuffer.length);
                const frameCount = end - start;
                const interleaved = new Float32Array(frameCount * numChannels);
                for (let ch = 0; ch < numChannels; ch++) {
                    const channelData = audioBuffer.getChannelData(ch);
                    for (let f = 0; f < frameCount; f++) {
                        interleaved[f * numChannels + ch] = channelData[start + f];
                    }
                }
                const audioData = new AudioData({
                    format: 'f32',
                    sampleRate: audioBuffer.sampleRate,
                    numberOfFrames: frameCount,
                    numberOfChannels: numChannels,
                    timestamp: (start * 1000000) / audioBuffer.sampleRate,
                    data: interleaved
                });
                worker.postMessage({ type: 'AUDIO_DATA', data: { audioData } }, [audioData]);
                if (i % 50 === 0) await new Promise(r => setTimeout(r, 0));
            }

            // 5. Finalize
            worker.postMessage({ type: 'STOP' });

            worker.onmessage = (e) => {
                if (e.data.type === 'DONE') {
                    // Unblock tab closing
                    window.onbeforeunload = null;
                    
                    lastMp4Blob = new Blob([e.data.buffer], { type: 'video/mp4' });
                    
                    const url = URL.createObjectURL(lastMp4Blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `SYNDICATE_CRYSTAL_${Date.now()}.mp4`;
                    a.click();

                    // Cleanup
                    if (exportOverlay) {
                        exportOverlay.style.opacity = '0';
                        exportOverlay.style.pointerEvents = 'none';
                        setTimeout(() => {
                            exportOverlay.classList.add('hidden');
                            exportOverlay.style.display = 'none';
                        }, 700);
                    }
                    
                    isGhostExporting = false;
                    worker.terminate();
                }
            };
        };

        // --- Download Listeners ---
        downloadWebmBtn?.addEventListener('click', () => {
            if (!lastWebmBlob) return;
            const url = URL.createObjectURL(lastWebmBlob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `SYNDICATE_WEBM_${Date.now()}.webm`;
            a.click();
        });

        downloadMp4Btn?.addEventListener('click', () => {
            if (lastMp4Blob) {
                // If already generated, just download
                const url = URL.createObjectURL(lastMp4Blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `SYNDICATE_CRYSTAL_${Date.now()}.mp4`;
                a.click();
            } else {
                // Otherwise, trigger generation
                runGhostExport();
            }
        });

        closeChoiceBtn?.addEventListener('click', () => {
            if (choiceOverlay) {
                choiceOverlay.style.opacity = '0';
                choiceOverlay.style.pointerEvents = 'none';
                setTimeout(() => {
                    choiceOverlay.classList.add('hidden');
                    choiceOverlay.style.display = 'none';
                }, 500);
            }
        });

        // --- Listeners ---
        audioUpload.addEventListener('change', (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            if (!file) return;

            // Trigger error modal for potential 0-byte or corrupted files
            if (file.size === 0) {
                showErrorModal();
                return;
            }

            studioAudio.crossOrigin = "anonymous";
            studioAudio.src = URL.createObjectURL(file);
            studioAudio.load();
            
            // Background Audio Decoding for Ghost Render
            const prepareAudioBuffer = async () => {
                const ctx = audioContext || (initAudioEngine(), audioContext);
                if (!ctx) return;
                try {
                    const arrayBuffer = await file.arrayBuffer();
                    audioBuffer = await ctx.decodeAudioData(arrayBuffer);
                    console.log('[Audio] AudioBuffer Ready for Ghost Export:', audioBuffer.duration, 's');
                } catch (e) { console.error('[Audio] Decoding failed', e); }
            };
            prepareAudioBuffer();

            studioAudio.oncanplay = () => {
                hasLoadedFile = true;
                btnRecord.disabled = false;
                if (statusText) statusText.textContent = 'СЕМЯ ЗАГРУЖЕНО';
                connectAudioSource();
            };
            studioAudio.onerror = () => showErrorModal();
        });

        btnRecord.addEventListener('click', async () => {
            if (!hasLoadedFile) return;
            try {
                if (audioContext?.state === 'suspended') await audioContext.resume();
                studioAudio.currentTime = 0;
                
                // Set auto-stop when track ends
                studioAudio.onended = () => {
                    if (isRecording) executeStop();
                };

                await studioAudio.play();
                
                if (isAndroid) await new Promise(r => setTimeout(r, 150));
                
                setupRecorder();
                if (!mediaRecorder) return;

                if(uiLayer) { uiLayer.style.opacity = '0'; uiLayer.style.pointerEvents = 'none'; }
                if(stopLayer) { stopLayer.classList.remove('hidden'); setTimeout(() => stopLayer.style.opacity = '1', 50); }
                
                recordedChunks = [];
                recordStartTime = performance.now();
                // 100ms timeslice creates more frequent WebM clusters for precise seeking
                mediaRecorder.start(100);
                isRecording = true;
                if(statusText) statusText.textContent = 'ЗАПИСЬ...';
            } catch (err) { console.error('Record Start Fail:', err); }
        });

        btnStop.addEventListener('click', executeStop);
        if (closeModal) closeModal.onclick = () => hideErrorModal();

        // --- Draw Loop ---
        const ctx = canvas.getContext('2d');
        const cw = 720, ch = 1280;
        canvas.width = cw; canvas.height = ch;
        
        const gridCanvas = document.createElement('canvas');
        gridCanvas.width = cw; gridCanvas.height = ch;
        const gctx_grid = gridCanvas.getContext('2d');
        if (gctx_grid) {
            gctx_grid.strokeStyle = 'rgba(255, 255, 255, 0.012)';
            gctx_grid.lineWidth = 1;
            for(let x=0; x<cw; x+=40) { gctx_grid.moveTo(x,0); gctx_grid.lineTo(x,ch); }
            for(let y=0; y<ch; y+=40) { gctx_grid.moveTo(0,y); gctx_grid.lineTo(cw,y); }
            gctx_grid.stroke();
        }

        const renderFrame = (ctx: CanvasRenderingContext2D, data: Uint8Array, time: number, color: string, text: string, isOffline = false) => {
            const cw = 720, ch = 1280;
            
            // 1. Perfect clear for dark backgrounds
            ctx.clearRect(0, 0, cw, ch);
            ctx.fillStyle = '#000000'; 
            ctx.fillRect(0, 0, cw, ch);
            
            ctx.drawImage(gridCanvas, 0, 0);

            const isDormant = !isOffline && (!hasLoadedFile || studioAudio.paused);
            let bass = 0, vocals = 0;

            if (!isDormant && data) {
                let bSum = 0, vSum = 0;
                for(let i=0; i<8; i++) bSum += data[i];
                for(let i=5; i<45; i++) vSum += data[i];
                bass = bSum/8; vocals = vSum/40;
            } else {
                bass = 20 + Math.sin(time*3)*15;
                vocals = 15 + Math.sin(time*5)*10;
            }

            const pulse = Math.sin(time) * 2;
            const breathe = isDormant ? Math.sin(time * 2.5) : 0; 
            const anger = isDormant ? (-14 + breathe) : Math.pow(vocals / 255, 2.5) * 25; 
            const eyeGlow = 40 + (isDormant ? breathe*3 : Math.pow(vocals/255, 2) * 50);

            ctx.save();
            const msg = text.toUpperCase();
            ctx.font = '20px monospace'; ctx.textAlign = 'center'; ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.letterSpacing = '8px'; ctx.fillText(msg, cw/2, ch*0.82);

            ctx.translate(cw/2, ch*0.48);
            const scale = (cw*0.8/120) + (bass/255)*0.5;
            ctx.scale(scale, scale);
            
            // 2. Clean Shadows-Free Mouth
            ctx.fillStyle = `rgba(${color}, 0.9)`;
            const numBars = 25;
            const mouthY = 20 + pulse;
            for (let i = 0; i < numBars; i++) {
                const val = isDormant ? 0 : data[5 + Math.floor(i * (40/numBars))];
                const taper = 1 - Math.pow(i/numBars, 2);
                const h = isDormant ? (2+breathe)*taper+1 : (Math.pow(val/255, 3)*70*taper)+2;
                const xRight = i*2.8; const xLeft = -i*2.8 - 2.8;
                ctx.fillRect(xRight + 1.4, mouthY, 1.5, h);
                ctx.fillRect(xLeft + 1.4, mouthY, 1.5, h);
                const uH = h*0.5 + (isDormant?1:2);
                ctx.fillRect(xRight + 1.4, mouthY - uH - 4, 1.5, uH);
                ctx.fillRect(xLeft + 1.4, mouthY - uH - 4, 1.5, uH);
            }

            // 3. Glowing Eyes (Layered OVER mouth for depth)
            ctx.save();
            ctx.shadowBlur = eyeGlow;
            ctx.shadowColor = `rgba(${color}, 1)`;
            ctx.fillStyle = `rgba(${color}, 0.98)`;
            
            // Eye Paths
            ctx.beginPath();
            if(isDormant) {
                ctx.moveTo(-50, -45 + pulse); ctx.lineTo(-15, -38 + pulse); ctx.lineTo(-45, -43 + pulse);
            } else {
                ctx.moveTo(-55, -50 + pulse); ctx.lineTo(-15, -28 + anger + pulse); ctx.lineTo(-30, -35 + pulse);
            }
            ctx.fill();
            
            ctx.beginPath();
            if(isDormant) {
                ctx.moveTo(50, -45 + pulse); ctx.lineTo(15, -38 + pulse); ctx.lineTo(45, -43 + pulse);
            } else {
                ctx.moveTo(55, -50 + pulse); ctx.lineTo(15, -28 + anger + pulse); ctx.lineTo(30, -35 + pulse);
            }
            ctx.fill();
            ctx.restore();
            
            ctx.restore();
        };

        let time = 0;
        const draw = () => {
            if (!ctx) return;
            requestAnimationFrame(draw);
            
            const data = new Uint8Array(analyser ? analyser.frequencyBinCount : 512);
            if (analyser && !studioAudio.paused) {
                analyser.getByteFrequencyData(data);
            }
            
            time += 0.015;
            renderFrame(ctx, data, time, selectedColor, (studioTextInput?.value || 'СИНДИКАТ').toUpperCase());
        };
        draw();
    });
</script>

