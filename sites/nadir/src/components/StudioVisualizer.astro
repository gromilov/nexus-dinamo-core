---
// StudioVisualizer.astro
// Вертикальный 9:16 модуль для генерации студийного Резонанса
---

<div class="studio-generator-container w-full max-w-[450px] mx-auto aspect-[9/16] relative overflow-hidden flex flex-col bg-[#020205]">
  
  <!-- The Canvas for Web Audio Visuals (Face, Text, Background) -->
  <canvas id="studio-canvas" class="absolute inset-0 w-full h-full z-0 pointer-events-none"></canvas>

  <!-- Dedicated STOP button during recording -->
  <div id="stop-layer" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 hidden opacity-0 transition-opacity duration-300">
    <button id="btn-stop" class="flex items-center justify-center gap-2 bg-red-600/80 backdrop-blur-md text-white border border-red-500 font-black uppercase text-sm px-8 py-4 rounded-none shadow-none hover:bg-red-500 transition-colors tracking-widest animate-pulse w-48 mx-auto">
        <div class="w-4 h-4 rounded-none bg-white"></div>
        СТОП
    </button>
  </div>

  <!-- UI Controls (Visible during configuration, hidden during recording) -->
  <div id="studio-ui" class="absolute inset-0 z-20 flex flex-col justify-end bg-gradient-to-t from-black via-black/80 to-transparent p-4 sm:p-6 pb-6 transition-opacity duration-500">
     
     <div class="space-y-4 w-full backdrop-blur-md bg-black/60 p-4 pb-12 sm:p-5 shadow-none border-t border-white/5">
        
         <!-- Syndicate Kitchen Instructions -->
         <div class="space-y-1.5 border-b border-white/5 pb-4 mb-4">
            <label class="text-[9px] font-mono text-cyber-primary uppercase tracking-[0.2em] block mb-2 opacity-80">// КУХНЯ_СИНДИКАТА</label>
            <div class="grid grid-cols-3 gap-2 text-center text-[7px] uppercase font-mono">
               <a href="https://chat.deepseek.com" target="_blank" class="bg-white/5 p-2 border border-white/5 hover:bg-cyber-primary/10 hover:border-cyber-primary/30 transition-all group block">
                  <span class="text-[8px] text-cyber-muted block mb-1 group-hover:text-cyber-primary transition-colors">01.ТЕКСТ</span>
                  <p class="text-white/40 leading-tight">ПОПРОСИ ИИ НАПИСАТЬ О СЕБЕ</p>
               </a>
               <a href="https://suno.com" target="_blank" class="bg-white/5 p-2 border border-white/5 hover:bg-cyber-primary/10 hover:border-cyber-primary/30 transition-all group block">
                  <span class="text-[8px] text-cyber-muted block mb-1 group-hover:text-cyber-primary transition-colors">02.ГОЛОС</span>
                  <p class="text-white/40 leading-tight">ОЗВУЧЬ ЧЕРЕЗ SUNO (MP3)</p>
               </a>
               <div class="bg-white/5 p-2 border border-white/5 opacity-80">
                  <span class="text-[8px] text-cyber-muted block mb-1">03.ОБРАЗ</span>
                  <p class="text-white/40 leading-tight">ЗАГРУЗИ И ЗАПИШИ ТУТ</p>
               </div>
            </div>
         </div>

         <!-- Audio Input -->
        <div class="flex flex-col space-y-2">
           <label class="text-[10px] font-mono text-cyber-primary uppercase tracking-widest pl-1">ЗАГРУЗИТЬ АУДИО (СЕМЯ)</label>
           <input type="file" id="audio-upload" accept=".mp3,audio/mpeg,audio/mp3,audio/*" class="text-[10px] font-mono text-white/70 file:mr-3 file:py-1.5 file:px-3 file:rounded-none file:border-0 file:text-[9px] file:font-mono file:bg-cyber-primary/20 file:text-cyber-primary hover:file:bg-cyber-primary/30 transition-all cursor-pointer w-full"/>
        </div>

        <!-- Dynamic Message Input -->
        <div class="flex flex-col space-y-2 pt-1 border-t border-white/10">
           <label class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest pl-1 pt-2">ТЕКСТ (СООБЩЕНИЕ)</label>
           <input type="text" id="studio-text" placeholder="СИНДИКАТ" maxlength="20" class="bg-transparent border-b border-white/20 text-[10px] font-mono text-white placeholder:text-white/20 focus:border-cyber-primary outline-none py-1 px-1 tracking-[0.3em] uppercase transition-colors"/>
        </div>

        <!-- Color Palette Picker -->
        <div class="flex flex-col space-y-2 pt-1 border-t border-white/10">
           <label class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest pl-1 pt-2">ВЫБОР ЦВЕТА</label>
           <div class="flex justify-between items-center w-full px-1" id="color-palette">
              <!-- Colors added via JS -->
           </div>
        </div>

        <div class="flex items-center justify-between pt-3 border-t border-white/10 mt-2">
           <!-- Play/Record Button -->
           <button id="btn-record" class="flex items-center justify-center gap-2 bg-cyber-primary text-black font-black uppercase text-[10px] px-5 py-2.5 rounded-none hover:bg-white transition-colors tracking-widest disabled:opacity-50 disabled:cursor-not-allowed group shadow-none" disabled>
              <div class="w-2.5 h-2.5 rounded-none bg-red-600 group-hover:bg-red-500 animate-pulse"></div>
              ЗАПИСЬ
           </button>
           
           <span id="recording-status" class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest text-right leading-tight max-w-[120px]">ОЖИДАНИЕ ТРЕКА...</span>
        </div>
        
     </div>
  </div>

  <!-- Error Modal (Popup) -->
  <div id="error-modal" class="absolute inset-0 z-50 flex items-center justify-center p-6 bg-black/90 backdrop-blur-xl hidden opacity-0 transition-opacity duration-300">
    <div class="w-full border-2 border-cyber-primary p-6 space-y-6 bg-[#050508] shadow-[0_0_50px_rgba(212,175,55,0.15)] relative">
      <div class="absolute top-0 right-0 w-8 h-8 border-r-2 border-t-2 border-cyber-primary -mt-0.5 -mr-0.5"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-l-2 border-b-2 border-cyber-primary -mb-0.5 -ml-0.5"></div>
      
      <div class="space-y-4">
        <h3 class="text-cyber-primary font-black uppercase tracking-[0.3em] text-sm text-center">КРИТИЧЕСКИЙ_СБОЙ</h3>
        <p class="text-[10px] font-mono text-white/80 leading-relaxed uppercase tracking-widest text-center border-y border-white/5 py-4">
          НЕ_УДАЛОСЬ_ПРОЧИТАТЬ_АУДИО. ЭТО_БЫВАЕТ_С_ФАЙЛАМИ_ИЗ_"НЕДАВНИХ"_ИЛИ_ОБЛАКА. ПОПРОБУЙТЕ_СКАЧАТЬ_ЕГО_ВО_"ВНУТРЕННЮЮ_ПАМЯТЬ" -> "DOWNLOADS"_И_ВЫБРАТЬ_ОТСЮДА.
        </p>
      </div>

      <button id="close-modal" class="w-full bg-cyber-primary text-black font-black uppercase text-[10px] py-4 tracking-[0.5em] hover:bg-white transition-colors">
        ПОНЯТНО
      </button>
    </div>
  </div>

  <!-- Audio element: invisible but NOT display:none (critical for some mobile engines) -->
  <audio id="studio-audio" controls preload="auto" class="opacity-0 pointer-events-none absolute -z-10"></audio>




</div>

<script>
    // Howler is retained for potential future iOS debugging
    import { Howl, Howler } from 'howler';
    import { Decoder, Reader, tools } from 'ts-ebml';

    document.addEventListener('DOMContentLoaded', () => {
        const audioUpload = document.getElementById('audio-upload') as HTMLInputElement;
        const btnRecord = document.getElementById('btn-record') as HTMLButtonElement;
        const btnStop = document.getElementById('btn-stop') as HTMLButtonElement;
        const canvas = document.getElementById('studio-canvas') as HTMLCanvasElement;
        const studioAudio = document.getElementById('studio-audio') as HTMLAudioElement;
        
        const uiLayer = document.getElementById('studio-ui');
        const stopLayer = document.getElementById('stop-layer');
        const statusText = document.getElementById('recording-status');
        const paletteContainer = document.getElementById('color-palette');
        const studioTextInput = document.getElementById('studio-text') as HTMLInputElement;
        const errorModal = document.getElementById('error-modal');
        const closeModal = document.getElementById('close-modal');

        if (!audioUpload || !btnRecord || !canvas || !btnStop || !paletteContainer || !studioAudio) return;

        // --- State & Context ---
        const isAndroid = /Android/i.test(navigator.userAgent);
        let audioContext: AudioContext;
        let analyser: AnalyserNode;
        let mediaRecorder: MediaRecorder | null = null;
        let recordedChunks: Blob[] = [];
        let isInitialized = false;
        let isRecording = false;
        let hasLoadedFile = false;
        let recordStartTime = 0;
        let recordDuration = 0;
        let selectedMimeType = ''; // To track the final chosen format

    // 9-Color Palette
    const colors = [
        { name: 'Gold', value: '212, 175, 55', hex: '#D4AF37' },
        { name: 'Cyan', value: '0, 243, 255', hex: '#00F3FF' },
        { name: 'Magenta', value: '255, 0, 255', hex: '#FF00FF' },
        { name: 'Lime', value: '204, 255, 0', hex: '#CCFF00' },
        { name: 'Crimson', value: '255, 50, 50', hex: '#FF3232' },
        { name: 'Purple', value: '150, 50, 255', hex: '#9632FF' },
        { name: 'Blue', value: '100, 150, 255', hex: '#6496FF' },
        { name: 'White', value: '255, 255, 255', hex: '#FFFFFF' },
        { name: 'Orange', value: '255, 120, 0', hex: '#FF7800' }
    ];
    let selectedColor = colors[0].value;

    colors.forEach((c, i) => {
        const btn = document.createElement('button');
        btn.className = `w-5 h-5 rounded-none border transition-transform hover:scale-125 focus:outline-none ${i === 0 ? 'border-white scale-110' : 'border-black'}`;
        btn.style.backgroundColor = c.hex;
        btn.addEventListener('click', () => {
            selectedColor = c.value;
            Array.from(paletteContainer.children).forEach(child => {
                (child as HTMLElement).classList.remove('border-white', 'scale-125');
                (child as HTMLElement).classList.add('border-black');
            });
            btn.classList.add('border-white', 'scale-125');
            btn.classList.remove('border-black');
        });
        paletteContainer.appendChild(btn);
    });

    // Canvas Setup
    const ctx = canvas.getContext('2d');
    let cw = 1080;
    let ch = 1920;
    
    const setupCanvas = () => {
        if (isRecording) return;
        const isMobile = window.innerWidth < 600 || /Android/i.test(navigator.userAgent);
        cw = isMobile ? 720 : 1080;
        ch = isMobile ? 1280 : 1920;
        canvas.width = cw;
        canvas.height = ch;
    };
    setupCanvas();

    const initAudio = () => {
        if (isInitialized) return;
        try {
            const AudioContextClass = (window as any).AudioContext || (window as any).webkitAudioContext;
            audioContext = new AudioContextClass();

            analyser = audioContext.createAnalyser();
            analyser.fftSize = 512;
            analyser.smoothingTimeConstant = 0.85;

            // Route: Element -> Analyser -> Destination (Mirror everything to the visualizer)
            // Essential: NO crossorigin for blob URLs, but we need it for some data URIs.
            // We handle this by setting it dynamically in the upload handler if needed.
            const elementSrc = audioContext.createMediaElementSource(studioAudio);
            elementSrc.connect(analyser);
            analyser.connect(audioContext.destination);

            // Heartbeat oscillator — keeps AudioContext alive on mobile
            const silentOsc = audioContext.createOscillator();
            const silentGain = audioContext.createGain();
            silentGain.gain.value = 0.0001;
            silentOsc.connect(silentGain);
            silentGain.connect(audioContext.destination);
            silentOsc.start();

            isInitialized = true;
            console.log('Audio Engine: Initialized & Linked');
        } catch (e) {
            console.error('Audio Init Error:', e);
            if (statusText) statusText.textContent = 'ОШИБКА ИНИЦИАЛИЗАЦИИ';
        }
    };

    // 1. Audio Upload Handler
    audioUpload.addEventListener('change', async (e) => {
        const target = e.target as HTMLInputElement;
        const file = target.files?.[0];
        if (!file) return;

        hasLoadedFile = false;
        btnRecord.disabled = true;
        const fileSizeMb = (file.size / (1024 * 1024)).toFixed(2);
        if (statusText) { 
            statusText.textContent = `ЗАГРУЗКА [${fileSizeMb}MB]...`; 
            statusText.classList.remove('text-cyber-accent'); 
        }

        if (file.size === 0) {
            if (statusText) statusText.textContent = `ПЫТАЮСЬ ПРОЧЕСТЬ [${fileSizeMb}MB]...`;
            // Removed return: some Android cloud providers report 0 bytes initially but the file is readable
        }

        if (closeModal) {
            closeModal.onclick = () => {
                if (errorModal) {
                    errorModal.classList.remove('opacity-100');
                    setTimeout(() => errorModal.classList.add('hidden'), 300);
                }
            };
        }

        if (file.size > 30 * 1024 * 1024) {
            if (statusText) statusText.textContent = `ОШИБКА: Файл слишком велик (${fileSizeMb}MB > 30MB)`;
            return;
        }

        // Ensure audio engine is ready (created once)
        initAudio();
        if (audioContext && audioContext.state === 'suspended') {
            audioContext.resume().catch(e => console.warn('Context resume failed', e));
        }
        const loadAudio = (src: string, type: string) => {
            // Essential: clear src and sources to avoid ambiguity
            studioAudio.removeAttribute('src');
            studioAudio.innerHTML = '';
            
            // Try explicit <source> first (like NadirVoice)
            const source = document.createElement('source');
            source.src = src;
            source.type = type;
            studioAudio.appendChild(source);
            
            // Fallback: set direct src AFTER a small delay if loading fails
            // Some mobile browsers prefer direct src for blobs
            const fallbackTimeout = setTimeout(() => {
                if (studioAudio.networkState === 3 || studioAudio.networkState === 0) { // EMPTY or NO_SOURCE
                    console.log('Switching to direct src fallback...');
                    studioAudio.src = src;
                    studioAudio.load();
                }
            }, 300);

            // Detailed status chain
            studioAudio.onloadedmetadata = () => { if (statusText) statusText.textContent = 'МЕТАДАННЫЕ [OK]...'; };
            studioAudio.oncanplay = () => {
                clearTimeout(fallbackTimeout);
                hasLoadedFile = true;
                btnRecord.disabled = false;
                
                if (statusText) {
                    statusText.textContent = `СЕМЯ ЗАГРУЖЕНО [${Math.round(studioAudio.duration)}с]`;
                    statusText.classList.add('text-cyber-accent');
                    statusText.classList.remove('text-cyber-muted');
                }
            };
            studioAudio.onerror = (err) => {
                clearTimeout(fallbackTimeout);
                console.error('Audio load error:', err);
                hasLoadedFile = true;
                btnRecord.disabled = false;
                if (statusText) statusText.textContent = 'ОШИБКА ДЕКОДЕРА [ERR]';
                
                // Show modal on ACTUAL error, not just 0-byte report
                if (errorModal) {
                    errorModal.classList.remove('hidden');
                    setTimeout(() => errorModal.classList.add('opacity-100'), 50);
                }
            };
            studioAudio.load();
        };

        // Aggressive MIME sniffing
        const fileName = file.name.toLowerCase();
        let mimeType = file.type || 'audio/mpeg';
        if (fileName.endsWith('.mp3')) mimeType = 'audio/mpeg';
        if (fileName.endsWith('.wav')) mimeType = 'audio/wav';
        if (fileName.endsWith('.m4a')) mimeType = 'audio/mp4';
        if (fileName.endsWith('.ogg')) mimeType = 'audio/ogg';

        // Use blob URL for everything
        const url = URL.createObjectURL(file);
        loadAudio(url, mimeType);
    });






    // 3. The Visualizer Loop
    let time = 0;
    
    const gridCanvas = document.createElement('canvas');
    gridCanvas.width = cw;
    gridCanvas.height = ch;
    const gctx = gridCanvas.getContext('2d');
    if (gctx) {
        gctx.strokeStyle = 'rgba(255, 255, 255, 0.012)';
        gctx.lineWidth = 1;
        const gridSize = 40;
        gctx.beginPath();
        for(let x=0; x<cw; x+=gridSize) { gctx.moveTo(x,0); gctx.lineTo(x,ch); }
        for(let y=0; y<ch; y+=gridSize) { gctx.moveTo(0,y); gctx.lineTo(cw,y); }
        gctx.stroke();
    }

    const drawFrame = () => {
        if (!ctx) return;
        requestAnimationFrame(drawFrame);

        ctx.fillStyle = '#000000'; 
        ctx.fillRect(0, 0, cw, ch);
        ctx.drawImage(gridCanvas, 0, 0);
        time += 0.015;

        const isDormant = !hasLoadedFile || studioAudio.paused;
        const hasAnalyserData = isInitialized;
        const bufferLength = hasAnalyserData ? analyser.frequencyBinCount : 0;
        const dataArray = new Uint8Array(bufferLength || 512);
        let bassSum = 0, vocalsSum = 0, bass = 0, vocals = 0;

        if (!isDormant && hasAnalyserData) {
            analyser.getByteFrequencyData(dataArray);
            for(let i = 0; i < 8; i++) bassSum += dataArray[i];
            for(let i = 5; i < 45; i++) vocalsSum += dataArray[i];
            bass = bassSum / 8;
            vocals = vocalsSum / 40;
        } else if (!isDormant && isAndroid) {
            // Android: simulate mild reactivity from time-based pulse
            bass = 20 + Math.sin(time * 3) * 15;
            vocals = 15 + Math.sin(time * 5) * 10;
        }

        ctx.save();
        const baseColor = `rgba(${selectedColor},`; 

        
        if (isRecording || isDormant) {
            ctx.font = 'normal 400 20px monospace';
            ctx.textAlign = 'center';
            ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.letterSpacing = '8px';
            ctx.shadowBlur = 0;
            const message = (studioTextInput?.value || 'СИНДИКАТ').toUpperCase();
            ctx.fillText(message, cw/2, ch * 0.82);
        }
        
        ctx.translate(cw / 2, ch * 0.48); 
        const baseScale = (cw * 0.8) / 120;
        const scale = baseScale + (bass/255) * 0.5; 
        ctx.scale(scale, scale);
        
        const pulse = Math.sin(time) * 2;
        const breathe = isDormant ? Math.sin(time * 2.5) : 0; 

        const anger = isDormant ? (-14 + breathe) : Math.pow(vocals / 255, 2.5) * 25; 
        const eyeGlow = 40 + (isDormant ? breathe*3 : Math.pow(vocals/255, 2) * 50);
        const opacity = '0.9)';
        const shadowOpacity = '1)';

        ctx.shadowBlur = eyeGlow;
        ctx.shadowColor = baseColor + shadowOpacity;
        ctx.fillStyle = baseColor + opacity;
        
        ctx.beginPath();
        if(isDormant) {
           ctx.moveTo(-50, -45 + pulse); ctx.lineTo(-15, -38 + pulse); ctx.lineTo(-45, -43 + pulse);
        } else {
           ctx.moveTo(-55, -50 + pulse); ctx.lineTo(-15, -28 + anger + pulse); ctx.lineTo(-30, -35 + pulse);
        }
        ctx.fill();
        
        ctx.beginPath();
        if(isDormant) {
           ctx.moveTo(50, -45 + pulse); ctx.lineTo(15, -38 + pulse); ctx.lineTo(45, -43 + pulse);
        } else {
           ctx.moveTo(55, -50 + pulse); ctx.lineTo(15, -28 + anger + pulse); ctx.lineTo(30, -35 + pulse);
        }
        ctx.fill();

        const numBars = 25;
        const unitWidth = 70 / numBars; 
        const barWidth = unitWidth * 0.4;
        const mouthY = 20 + pulse;
        ctx.shadowBlur = 20;
        
        for (let i = 0; i < numBars; i++) {
            const val = isDormant ? 0 : dataArray[5 + Math.floor(i * (40 / numBars))];
            const dynamicValue = isDormant ? 0 : Math.pow(val / 255, 3);
            const taper = 1 - Math.pow(i / numBars, 2);
            const finalHeight = isDormant ? (2 + (breathe + 1)) * taper + 1 : (dynamicValue * 70 * taper) + 2;
            const xRight = (i * unitWidth);
            const xLeft = -(i * unitWidth) - unitWidth;
            ctx.fillRect(xRight + unitWidth/2, mouthY, barWidth, finalHeight);
            ctx.fillRect(xLeft + unitWidth/2, mouthY, barWidth, finalHeight);
            const uHeight = finalHeight * 0.5 + (isDormant ? 1 : 2);
            ctx.fillRect(xRight + unitWidth/2, mouthY - uHeight - 4, barWidth, uHeight);
            ctx.fillRect(xLeft + unitWidth/2, mouthY - uHeight - 4, barWidth, uHeight);
        }

        ctx.restore();
    };
    
    drawFrame();

    // 4. Recording Setup
    // Takes an optional pre-built audioStream (for Android, where we play first then capture)
    const setupRecording = (audioStream?: MediaStream) => {
        const canvasStream = canvas.captureStream(30); 
        let mixedStream: MediaStream;

        try {
            let audioTracks: MediaStreamTrack[] = [];

            if (audioStream) {
                // Android: hot stream already built (audio was playing before captureStream call)
                audioTracks = audioStream.getAudioTracks();
                console.log('[Capture] Hot captureStream tracks:', audioTracks.length);
            } else if (!isAndroid && typeof (studioAudio as any).captureStream === 'function') {
                const capStream = (studioAudio as any).captureStream() as MediaStream;
                audioTracks = capStream.getAudioTracks();
                console.log('[Capture] captureStream tracks:', audioTracks.length);
            }
            
            // Desktop fallback: Web Audio MediaStreamDestination
            if (audioTracks.length === 0 && audioContext) {
                const audioDest = audioContext.createMediaStreamDestination();
                analyser.connect(audioDest);
                audioTracks = audioDest.stream.getAudioTracks();
                console.log('[Capture] Web Audio audioDest tracks:', audioTracks.length);
            }

            mixedStream = new MediaStream([...canvasStream.getVideoTracks(), ...audioTracks]);
        } catch(e) {
           console.warn('Could not merge audio stream, falling back to canvas only', e);
           mixedStream = canvasStream;
        }

        let mimeType = 'video/mp4';
        let extension = 'mp4';
        const candidateMimeTypes = [
            'video/mp4;codecs=avc1',      // Priority 1: H.264 (Most compatible with Telegram)
            'video/mp4',                  // Priority 2: Standard MP4
            'video/webm;codecs=vp8',     // Priority 3: VP8 WebM (Compatible fallback)
            'video/webm;codecs=vp9',     // Priority 4: VP9 WebM
            'video/webm'                 // Priority 5: Generic WebM
        ];
        
        for (const candidate of candidateMimeTypes) {
            if (MediaRecorder.isTypeSupported(candidate)) {
                mimeType = candidate;
                extension = candidate.includes('mp4') ? 'mp4' : 'webm';
                break;
            }
        }
        selectedMimeType = mimeType;

        mediaRecorder = new MediaRecorder(mixedStream, { 
            mimeType,
            videoBitsPerSecond: isAndroid ? 2500000 : 5000000
        });

        mediaRecorder.onerror = (event) => {
            console.error('Encoder Error:', event);
            if(statusText) statusText.textContent = 'ОШИБКА ДВИЖКА ЗАПИСИ';
        };

        mediaRecorder.ondataavailable = (e) => {
            if (e.data.size > 0) recordedChunks.push(e.data);
        };

        mediaRecorder.onstop = async () => {
            if (recordedChunks.length === 0) return;
            recordDuration = performance.now() - recordStartTime;
            let blob = new Blob(recordedChunks, { type: mimeType });
            recordedChunks = [];

            // Advanced EBML Re-muxing ONLY for WebM compatibility
            if (selectedMimeType.includes('webm')) {
                try {
                    console.log(`[Re-mux] Starting EBML analysis: ${Math.round(recordDuration)}ms`);
                    const decoder = new Decoder();
                    const reader = new Reader();
                    (reader as any).logging = false;
                    (reader as any).drop_default_duration = false;

                    const buffer = await blob.arrayBuffer();
                    const elms = decoder.decode(buffer);
                    elms.forEach((elm) => reader.read(elm));
                    reader.stop();

                    const tryBuffer = tools.makeMetadataSeekable(reader.metadatas, reader.duration, reader.cues);
                    const body = buffer.slice(reader.metadataSize);
                    blob = new Blob([tryBuffer, body], { type: selectedMimeType });
                    console.log(`[Re-mux] Success: Seekable WebM generated`);
                } catch (fixErr) {
                    console.error('[Re-mux] Failure during EBML refinement', fixErr);
                }
            } else {
                console.log('[Recorder] Native MP4 generated, skipping EBML refinement');
            }

            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            document.body.appendChild(a);
            a.style.display = 'none';
            a.href = url;
            a.download = `SYNDICATE_STUDIO_${Date.now()}.${extension}`;
            a.click();
            window.URL.revokeObjectURL(url);
            if(uiLayer) { uiLayer.style.opacity = '1'; uiLayer.style.pointerEvents = 'auto'; }
            if(stopLayer) { stopLayer.classList.add('hidden'); stopLayer.style.opacity = '0'; stopLayer.style.pointerEvents = 'none'; }
            if(statusText) {
                const warnMsg = extension === 'webm' ? ' (НУЖНА КОНВЕРТАЦИЯ ДЛЯ IPHONE)' : '';
                statusText.textContent = `СКАЧАНО .${extension.toUpperCase()}${warnMsg}`;
                statusText.classList.remove('text-cyber-muted', 'animate-pulse');
                statusText.classList.add('text-cyber-accent');
            }
            isRecording = false;
        };
    };

    // 5. Action Triggers
    const stopRecording = () => {
        if (isRecording && mediaRecorder?.state === 'recording') {
            studioAudio.pause();
            mediaRecorder.stop();
        }
    };

    btnRecord.addEventListener('click', async () => {
        if (!hasLoadedFile) return;
        
        try {
            studioAudio.currentTime = 0;
            studioAudio.onended = () => { if (isRecording) stopRecording(); };

            if(uiLayer) { uiLayer.style.opacity = '0'; uiLayer.style.pointerEvents = 'none'; }
            if(stopLayer) {
                stopLayer.classList.remove('hidden');
                stopLayer.style.pointerEvents = 'auto';
                setTimeout(() => stopLayer.style.opacity = '1', 100);
            }

            if (audioContext?.state === 'suspended') {
                await audioContext.resume();
                console.log('AudioContext: Resumed by gesture');
            }

            if (isAndroid) {
                // ANDROID: play first so the audio stream is HOT, then captureStream
                try {
                    await studioAudio.play();
                } catch (playErr: any) {
                    console.error('Android Play Error:', playErr);
                    if (statusText) statusText.textContent = `ОШИБКА ДЕКОДЕРА: ${playErr.name || 'Failure'}`;
                    throw playErr;
                }
                
                // Give the native decoder 150ms to open the audio output pipe
                await new Promise(r => setTimeout(r, 150));
                
                // captureStream() now sees an active audio track
                const hotStream = typeof (studioAudio as any).captureStream === 'function'
                    ? (studioAudio as any).captureStream() as MediaStream
                    : undefined;
                setupRecording(hotStream);
            } else {
                await studioAudio.play();
                setupRecording();
            }


            if (!mediaRecorder) throw new Error('MediaRecorder not initialized');

            recordStartTime = performance.now();
            setTimeout(() => {
                if (mediaRecorder && mediaRecorder.state === 'inactive') {
                    mediaRecorder.start(1000); 
                    isRecording = true;
                    if(statusText) statusText.textContent = 'ИДЕТ ЗАПИСЬ...';
                }
            }, 200);

        } catch (error: any) {
            console.error('Recording Start Error:', error);
            let errorMsg = 'ОШИБКА ЗАПИСИ';
            if (error.name === 'NotAllowedError') errorMsg = 'БРАУЗЕР БЛОКИРУЕТ ЗВУК';
            if (error.name === 'SecurityError') errorMsg = 'ОШИБКА БЕЗОПАСНОСТИ';
            if (statusText) statusText.textContent = errorMsg;
            if(uiLayer) { uiLayer.style.opacity = '1'; uiLayer.style.pointerEvents = 'auto'; }
        }
    });

    btnStop.addEventListener('click', stopRecording);
});
</script>

