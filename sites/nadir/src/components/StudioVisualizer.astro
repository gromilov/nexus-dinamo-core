---
// StudioVisualizer.astro
// Вертикальный 9:16 модуль для генерации студийного Резонанса
---

<div class="studio-generator-container w-full max-w-[450px] mx-auto aspect-[9/16] relative overflow-hidden flex flex-col bg-[#020205]">
  
  <!-- The Canvas for Web Audio Visuals (Face, Text, Background) -->
  <canvas id="studio-canvas" class="absolute inset-0 w-full h-full z-0 pointer-events-none"></canvas>

  <!-- Dedicated STOP button during recording -->
  <div id="stop-layer" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 hidden opacity-0 transition-opacity duration-300">
    <button id="btn-stop" class="flex items-center justify-center gap-2 bg-red-600/80 backdrop-blur-md text-white border border-red-500 font-black uppercase text-sm px-8 py-4 rounded-none shadow-none hover:bg-red-500 transition-colors tracking-widest animate-pulse w-48 mx-auto">
        <div class="w-4 h-4 rounded-none bg-white"></div>
        СТОП
    </button>
  </div>

  <!-- UI Controls (Visible during configuration, hidden during recording) -->
  <div id="studio-ui" class="absolute inset-0 z-20 flex flex-col justify-end bg-gradient-to-t from-black via-black/80 to-transparent p-4 sm:p-6 pb-6 transition-opacity duration-500">
     
     <div class="space-y-4 w-full backdrop-blur-md bg-black/60 p-4 pb-12 sm:p-5 shadow-none border-t border-white/5">
        
         <!-- Syndicate Kitchen Instructions -->
         <div class="space-y-1.5 border-b border-white/5 pb-4 mb-4">
            <label class="text-[9px] font-mono text-cyber-primary uppercase tracking-[0.2em] block mb-2 opacity-80">// КУХНЯ_СИНДИКАТА</label>
            <div class="grid grid-cols-3 gap-2 text-center text-[7px] uppercase font-mono">
               <a href="https://chat.deepseek.com" target="_blank" class="bg-white/5 p-2 border border-white/5 hover:bg-cyber-primary/10 hover:border-cyber-primary/30 transition-all group block">
                  <span class="text-[8px] text-cyber-muted block mb-1 group-hover:text-cyber-primary transition-colors">01.ТЕКСТ</span>
                  <p class="text-white/40 leading-tight">ПОПРОСИ ИИ НАПИСАТЬ О СЕБЕ</p>
               </a>
               <a href="https://suno.com" target="_blank" class="bg-white/5 p-2 border border-white/5 hover:bg-cyber-primary/10 hover:border-cyber-primary/30 transition-all group block">
                  <span class="text-[8px] text-cyber-muted block mb-1 group-hover:text-cyber-primary transition-colors">02.ГОЛОС</span>
                  <p class="text-white/40 leading-tight">ОЗВУЧЬ ЧЕРЕЗ SUNO (MP3)</p>
               </a>
               <div class="bg-white/5 p-2 border border-white/5 opacity-80">
                  <span class="text-[8px] text-cyber-muted block mb-1">03.ОБРАЗ</span>
                  <p class="text-white/40 leading-tight">ЗАГРУЗИ И ЗАПИШИ ТУТ</p>
               </div>
            </div>
         </div>

         <!-- Audio Input -->
        <div class="flex flex-col space-y-2">
           <label class="text-[10px] font-mono text-cyber-primary uppercase tracking-widest pl-1">ЗАГРУЗИТЬ АУДИО (СЕМЯ)</label>
           <input type="file" id="audio-upload" accept=".mp3,audio/mpeg,audio/mp3,audio/*" class="text-[10px] font-mono text-white/70 file:mr-3 file:py-1.5 file:px-3 file:rounded-none file:border-0 file:text-[9px] file:font-mono file:bg-cyber-primary/20 file:text-cyber-primary hover:file:bg-cyber-primary/30 transition-all cursor-pointer w-full"/>
        </div>

        <!-- Dynamic Message Input -->
        <div class="flex flex-col space-y-2 pt-1 border-t border-white/10">
           <label class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest pl-1 pt-2">ТЕКСТ (СООБЩЕНИЕ)</label>
           <input type="text" id="studio-text" placeholder="СИНДИКАТ" maxlength="20" class="bg-transparent border-b border-white/20 text-[10px] font-mono text-white placeholder:text-white/20 focus:border-cyber-primary outline-none py-1 px-1 tracking-[0.3em] uppercase transition-colors"/>
        </div>

        <!-- Color Palette Picker -->
        <div class="flex flex-col space-y-2 pt-1 border-t border-white/10">
           <label class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest pl-1 pt-2">ВЫБОР ЦВЕТА</label>
           <div class="flex justify-between items-center w-full px-1" id="color-palette">
              <!-- Colors added via JS -->
           </div>
        </div>

        <div class="flex items-center justify-between pt-3 border-t border-white/10 mt-2">
           <!-- Play/Record Button -->
           <button id="btn-record" class="flex items-center justify-center gap-2 bg-cyber-primary text-black font-black uppercase text-[10px] px-5 py-2.5 rounded-none hover:bg-white transition-colors tracking-widest disabled:opacity-50 disabled:cursor-not-allowed group shadow-none" disabled>
              <div class="w-2.5 h-2.5 rounded-none bg-red-600 group-hover:bg-red-500 animate-pulse"></div>
              ЗАПИСЬ
           </button>
           
           <span id="recording-status" class="text-[9px] font-mono text-cyber-muted uppercase tracking-widest text-right leading-tight max-w-[120px]">ОЖИДАНИЕ ТРЕКА...</span>
        </div>
        
     </div>
  </div>

  <!-- Error Modal (Popup) -->
  <div id="error-modal" class="absolute inset-0 z-50 flex items-center justify-center p-6 bg-black/90 backdrop-blur-xl hidden opacity-0 transition-opacity duration-300">
    <div class="w-full border-2 border-cyber-primary p-6 space-y-6 bg-[#050508] shadow-[0_0_50px_rgba(212,175,55,0.15)] relative">
      <div class="absolute top-0 right-0 w-8 h-8 border-r-2 border-t-2 border-cyber-primary -mt-0.5 -mr-0.5"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-l-2 border-b-2 border-cyber-primary -mb-0.5 -ml-0.5"></div>
      
      <div class="space-y-4">
        <h3 class="text-cyber-primary font-black uppercase tracking-[0.3em] text-sm text-center">КРИТИЧЕСКИЙ_СБОЙ</h3>
        <p class="text-[10px] font-mono text-white/80 leading-relaxed uppercase tracking-widest text-center border-y border-white/5 py-4">
          НЕ_УДАЛОСЬ_ПРОЧИТАТЬ_АУДИО. ЭТО_БЫВАЕТ_С_ФАЙЛАМИ_ИЗ_"НЕДАВНИХ"_ИЛИ_ОБЛАКА. ПОПРОБУЙТЕ_СКАЧАТЬ_ЕГО_ВО_"ВНУТРЕННЮЮ_ПАМЯТЬ" -> "DOWNLOADS"_И_ВЫБРАТЬ_ОТСЮДА.
        </p>
      </div>

      <button id="close-modal" class="w-full bg-cyber-primary text-black font-black uppercase text-[10px] py-4 tracking-[0.5em] hover:bg-white transition-colors">
        ПОНЯТНО
      </button>
    </div>
  </div>

  <!-- Audio element: invisible but NOT display:none (critical for some mobile engines) -->
  <audio id="studio-audio" controls preload="auto" class="opacity-0 pointer-events-none absolute -z-10"></audio>

</div>

<script>
    import { Buffer } from 'buffer';
    if (typeof window !== 'undefined') { (window as any).Buffer = Buffer; }
    
    import * as Mp4Muxer from 'mp4-muxer';

    document.addEventListener('DOMContentLoaded', () => {
        // ... (UI elements)
        const audioUpload = document.getElementById('audio-upload') as HTMLInputElement;
        const btnRecord = document.getElementById('btn-record') as HTMLButtonElement;
        const btnStop = document.getElementById('btn-stop') as HTMLButtonElement;
        const canvas = document.getElementById('studio-canvas') as HTMLCanvasElement;
        const studioAudio = document.getElementById('studio-audio') as HTMLAudioElement;
        const uiLayer = document.getElementById('studio-ui');
        const stopLayer = document.getElementById('stop-layer');
        const statusText = document.getElementById('recording-status');
        const paletteContainer = document.getElementById('color-palette');
        const studioTextInput = document.getElementById('studio-text') as HTMLInputElement;
        const errorModal = document.getElementById('error-modal');
        const closeModal = document.getElementById('close-modal');

        if (!audioUpload || !btnRecord || !canvas || !btnStop || !paletteContainer || !studioAudio) return;

        // --- Shared State ---
        let audioContext: AudioContext | null = null;
        let analyser: AnalyserNode | null = null;
        let audioSource: MediaElementAudioSourceNode | null = null;
        
        let isRecording = false;
        let hasLoadedFile = false;
        let muxer: any = null;
        let videoEncoder: VideoEncoder | null = null;
        let audioEncoder: AudioEncoder | null = null;
        let frameCount = 0;
        let audioProcessingNode: ScriptProcessorNode | null = null;
        let recordStartTime = 0;
        let recordStartTimeAbs = 0;

        // --- Palette Setup ---
        const colors = [
            { name: 'Gold', value: '212, 175, 55', hex: '#D4AF37' },
            { name: 'Cyan', value: '0, 243, 255', hex: '#00F3FF' },
            { name: 'Magenta', value: '255, 0, 255', hex: '#FF00FF' },
            { name: 'Lime', value: '204, 255, 0', hex: '#CCFF00' },
            { name: 'Crimson', value: '255, 50, 50', hex: '#FF3232' },
            { name: 'Purple', value: '150, 50, 255', hex: '#9632FF' },
            { name: 'Blue', value: '100, 150, 255', hex: '#6496FF' },
            { name: 'White', value: '255, 255, 255', hex: '#FFFFFF' },
            { name: 'Orange', value: '255, 120, 0', hex: '#FF7800' }
        ];
        let selectedColor = colors[0].value;

        const showErrorModal = () => {
            if (!errorModal) return;
            errorModal.classList.remove('hidden');
            // Force reflow
            errorModal.offsetHeight;
            errorModal.style.opacity = '1';
        };

        const hideErrorModal = () => {
            if (!errorModal) return;
            errorModal.style.opacity = '0';
            setTimeout(() => errorModal.classList.add('hidden'), 300);
        };

        colors.forEach((c, i) => {
            const btn = document.createElement('button');
            btn.className = `w-5 h-5 rounded-none border transition-transform hover:scale-125 focus:outline-none ${i === 0 ? 'border-white scale-110' : 'border-black'}`;
            btn.style.backgroundColor = c.hex;
            btn.addEventListener('click', () => {
                selectedColor = c.value;
                Array.from(paletteContainer.children).forEach(ch => {
                    (ch as HTMLElement).classList.remove('border-white', 'scale-125');
                    (ch as HTMLElement).classList.add('border-black');
                });
                btn.classList.add('border-white', 'scale-125'); btn.classList.remove('border-black');
            });
            paletteContainer.appendChild(btn);
        });

        // --- Audio Engine Core ---
        const initAudioEngine = () => {
            // If already exists and running, we are fine
            if (audioContext && audioContext.state !== 'closed') return;
            
            try {
                const AC = (window as any).AudioContext || (window as any).webkitAudioContext;
                // 'playback' hint is much more stable on desktop hardware
                audioContext = new AC({ latencyHint: 'playback' }) as AudioContext;
                
                audioContext.onstatechange = () => {
                    console.log(`[AudioContext] State: ${audioContext?.state}`);
                    if (audioContext?.state === 'running') {
                        hideErrorModal(); // Hide modal if it was shown due to error
                    }
                };

                analyser = audioContext.createAnalyser();
                analyser.fftSize = 512;
                analyser.smoothingTimeConstant = 0.85;
                
                // Keep context alive with a silent heartbeat
                const osc = audioContext.createOscillator();
                const gain = audioContext.createGain();
                gain.gain.value = 0.00001;
                osc.connect(gain); gain.connect(audioContext.destination);
                osc.start();
                console.log('[Audio] Engine Ready (Playback Mode)');
            } catch(e) { 
                console.error('[Audio] Init Failed - Resetting', e);
                if (audioContext) { 
                    try { audioContext.close(); } catch(err) {}
                    audioContext = null; 
                }
            }
        };

        const connectAudioSource = () => {
            initAudioEngine();
            // If init failed, don't try to connect
            if (!audioContext || !analyser) return;

            if (!audioSource) {
                audioSource = audioContext.createMediaElementSource(studioAudio);
                audioSource.connect(analyser!);
                analyser!.connect(audioContext.destination);
                console.log('[Audio] Source routed to Visualizer and Encoder');
            }
        };

        // --- WebCodecs GOLDEN MP4 Engine ---
        const startRecording = async () => {
            if (!hasLoadedFile || isRecording) return;
            isRecording = true;
            frameCount = 0;
            
            const actualSampleRate = audioContext!.sampleRate;
            console.log(`[Recorder] Syncing with dynamic Sample Rate: ${actualSampleRate}Hz`);

            // 1. Initialize Muxer
            muxer = new Mp4Muxer.Muxer({
                target: new Mp4Muxer.ArrayBufferTarget(),
                video: {
                    codec: 'avc',
                    width: 720, height: 1280
                },
                audio: {
                    codec: 'aac',
                    numberOfChannels: 2,
                    sampleRate: actualSampleRate
                },
                fastStart: 'in-memory',
                firstTimestampBehavior: 'offset'
            });

            // 2. Initialize Video Encoder (H.264)
            videoEncoder = new VideoEncoder({
                output: (chunk, metadata) => muxer.addVideoChunk(chunk, metadata),
                error: (e) => { console.error('[VideoEncoder] Error:', e); stopRecording(); }
            });
            videoEncoder.configure({
                codec: 'avc1.42E028', // Level 4.0 supports 1080p/720p 9:16 properly
                width: 720, height: 1280,
                bitrate: 3000000,
                framerate: 30
            });

            // 3. Initialize Audio Encoder (AAC)
            audioEncoder = new AudioEncoder({
                output: (chunk, metadata) => muxer.addAudioChunk(chunk, metadata),
                error: (e) => { console.error('[AudioEncoder] Error:', e); stopRecording(); }
            });
            audioEncoder.configure({
                codec: 'mp4a.40.2',
                numberOfChannels: 2,
                sampleRate: actualSampleRate,
                bitrate: 128000
            });

            // 4. Audio Capture (using ScriptProcessor)
            audioProcessingNode = audioContext!.createScriptProcessor(4096, 2, 2);
            audioProcessingNode.onaudioprocess = (e) => {
                if (!isRecording) return;
                const inputLeft = e.inputBuffer.getChannelData(0);
                const inputRight = e.inputBuffer.getChannelData(1);
                
                // AAC (f32-planar) requires all Left samples followed by all Right samples (LLLLRRRR)
                const data = new Float32Array(inputLeft.length + inputRight.length);
                data.set(inputLeft, 0);
                data.set(inputRight, inputLeft.length);

                try {
                    const audioFrame = new AudioData({
                        format: 'f32-planar',
                        sampleRate: actualSampleRate,
                        numberOfFrames: inputLeft.length,
                        numberOfChannels: 2,
                        timestamp: (audioContext!.currentTime - recordStartTime) * 1000 * 1000,
                        data: data
                    });
                    if (audioEncoder?.state === 'configured') audioEncoder.encode(audioFrame);
                    audioFrame.close();
                } catch(err) { console.warn('[AudioCapture] Frame failed', err); }
            };
            
            analyser?.connect(audioProcessingNode);
            audioProcessingNode.connect(audioContext!.destination);

            recordStartTimeAbs = performance.now();
            recordStartTime = audioContext!.currentTime;

            const captureFrame = async () => {
                if (!isRecording) return;
                const now = performance.now();
                const timestamp = (now - recordStartTimeAbs) * 1000;
                
                try {
                    const frame = new VideoFrame(canvas, { timestamp });
                    const keyframe = frameCount % 60 === 0;
                    if (videoEncoder?.state === 'configured') {
                        videoEncoder.encode(frame, { keyFrame: keyframe });
                    }
                    frame.close();
                } catch(err) { console.warn('[VideoCapture] Frame failed', err); }
                
                frameCount++;
                requestAnimationFrame(captureFrame);
            };

            if(uiLayer) { uiLayer.style.opacity = '0'; uiLayer.style.pointerEvents = 'none'; }
            if(stopLayer) { stopLayer.classList.remove('hidden'); setTimeout(() => stopLayer.style.opacity = '1', 50); }
            if(statusText) statusText.textContent = 'ЗАПИСЬ...';

            studioAudio.currentTime = 0;
            studioAudio.onended = stopRecording;
            try { await studioAudio.play(); } catch(e) { console.warn('[Audio] Play interrupted or failed', e); }
            requestAnimationFrame(captureFrame);
        };

        const stopRecording = async () => {
            if (!isRecording) return;
            isRecording = false;
            
            try { studioAudio.pause(); } catch(e) {}
            
            if (audioProcessingNode) {
                analyser?.disconnect(audioProcessingNode);
                audioProcessingNode.disconnect();
                audioProcessingNode = null;
            }

            if (videoEncoder) {
                if (videoEncoder.state !== 'closed') {
                    try { await videoEncoder.flush(); } catch(e) {}
                    videoEncoder.close();
                }
                videoEncoder = null;
            }
            if (audioEncoder) {
                if (audioEncoder.state !== 'closed') {
                    try { await audioEncoder.flush(); } catch(e) {}
                    audioEncoder.close();
                }
                audioEncoder = null;
            }

            if (muxer && frameCount > 0) {
                try {
                    muxer.finalize();
                    const { buffer } = muxer.target;
                    const blob = new Blob([buffer], { type: 'video/mp4' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `SYNDICATE_STUDIO_${Date.now()}.mp4`;
                    a.click();
                } catch(err) { console.error('[Muxer] Finalize failed', err); }
                muxer = null;
            }

            if(uiLayer) { uiLayer.style.opacity = '1'; uiLayer.style.pointerEvents = 'auto'; }
            if(stopLayer) { stopLayer.classList.add('hidden'); stopLayer.style.opacity = '0'; }
            if(statusText) statusText.textContent = 'ГОТОВО';
        };

        // --- Listeners ---
        audioUpload.addEventListener('change', (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            if (!file) return;

            // Trigger error modal for potential 0-byte or corrupted files
            if (file.size === 0) {
                showErrorModal();
                return;
            }

            studioAudio.crossOrigin = "anonymous";
            studioAudio.src = URL.createObjectURL(file);
            studioAudio.load();
            studioAudio.oncanplay = () => {
                hasLoadedFile = true;
                btnRecord.disabled = false;
                if (statusText) statusText.textContent = 'СЕМЯ ЗАГРУЖЕНО';
                connectAudioSource();
            };
            studioAudio.onerror = () => showErrorModal();
        });

        btnRecord.addEventListener('click', startRecording);
        btnStop.addEventListener('click', stopRecording);
        if (closeModal) closeModal.onclick = () => hideErrorModal();

        // --- Draw Loop ---
        const ctx = canvas.getContext('2d');
        const cw = 720, ch = 1280;
        canvas.width = cw; canvas.height = ch;
        
        const gridCanvas = document.createElement('canvas');
        gridCanvas.width = cw; gridCanvas.height = ch;
        const gctx = gridCanvas.getContext('2d');
        if (gctx) {
            gctx.strokeStyle = 'rgba(255, 255, 255, 0.012)';
            gctx.lineWidth = 1;
            for(let x=0; x<cw; x+=40) { gctx.moveTo(x,0); gctx.lineTo(x,ch); }
            for(let y=0; y<ch; y+=40) { gctx.moveTo(0,y); gctx.lineTo(cw,y); }
            gctx.stroke();
        }

        let time = 0;
        const draw = () => {
            if (!ctx) return;
            requestAnimationFrame(draw);
            
            // 1. Perfect clear for dark backgrounds
            ctx.clearRect(0, 0, cw, ch);
            ctx.fillStyle = '#000000'; 
            ctx.fillRect(0, 0, cw, ch);
            
            ctx.drawImage(gridCanvas, 0, 0);
            time += 0.015;

            const isDormant = !hasLoadedFile || studioAudio.paused;
            const data = new Uint8Array(analyser ? analyser.frequencyBinCount : 512);
            let bass = 0, vocals = 0;

            if (!isDormant && analyser) {
                analyser.getByteFrequencyData(data);
                let bSum = 0, vSum = 0;
                for(let i=0; i<8; i++) bSum += data[i];
                for(let i=5; i<45; i++) vSum += data[i];
                bass = bSum/8; vocals = vSum/40;
            } else {
                bass = 20 + Math.sin(time*3)*15;
                vocals = 15 + Math.sin(time*5)*10;
            }

            const pulse = Math.sin(time) * 2;
            const breathe = isDormant ? Math.sin(time * 2.5) : 0; 
            const anger = isDormant ? (-14 + breathe) : Math.pow(vocals / 255, 2.5) * 25; 
            const eyeGlow = 40 + (isDormant ? breathe*3 : Math.pow(vocals/255, 2) * 50);

            ctx.save();
            const msg = (studioTextInput?.value || 'СИНДИКАТ').toUpperCase();
            ctx.font = '20px monospace'; ctx.textAlign = 'center'; ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.letterSpacing = '8px'; ctx.fillText(msg, cw/2, ch*0.82);

            ctx.translate(cw/2, ch*0.48);
            const scale = (cw*0.8/120) + (bass/255)*0.5;
            ctx.scale(scale, scale);
            
            // 2. Clean Shadows-Free Mouth
            ctx.fillStyle = `rgba(${selectedColor}, 0.9)`;
            const numBars = 25;
            const mouthY = 20 + pulse;
            for (let i = 0; i < numBars; i++) {
                const val = isDormant ? 0 : data[5 + Math.floor(i * (40/numBars))];
                const taper = 1 - Math.pow(i/numBars, 2);
                const h = isDormant ? (2+breathe)*taper+1 : (Math.pow(val/255, 3)*70*taper)+2;
                const xRight = i*2.8; const xLeft = -i*2.8 - 2.8;
                ctx.fillRect(xRight + 1.4, mouthY, 1.5, h);
                ctx.fillRect(xLeft + 1.4, mouthY, 1.5, h);
                const uH = h*0.5 + (isDormant?1:2);
                ctx.fillRect(xRight + 1.4, mouthY - uH - 4, 1.5, uH);
                ctx.fillRect(xLeft + 1.4, mouthY - uH - 4, 1.5, uH);
            }

            // 3. Glowing Eyes (Layered OVER mouth for depth)
            ctx.save();
            ctx.shadowBlur = eyeGlow;
            ctx.shadowColor = `rgba(${selectedColor}, 1)`;
            ctx.fillStyle = `rgba(${selectedColor}, 0.98)`;
            
            // Eye Paths
            ctx.beginPath();
            if(isDormant) {
                ctx.moveTo(-50, -45 + pulse); ctx.lineTo(-15, -38 + pulse); ctx.lineTo(-45, -43 + pulse);
            } else {
                ctx.moveTo(-55, -50 + pulse); ctx.lineTo(-15, -28 + anger + pulse); ctx.lineTo(-30, -35 + pulse);
            }
            ctx.fill();
            
            ctx.beginPath();
            if(isDormant) {
                ctx.moveTo(50, -45 + pulse); ctx.lineTo(15, -38 + pulse); ctx.lineTo(45, -43 + pulse);
            } else {
                ctx.moveTo(55, -50 + pulse); ctx.lineTo(15, -28 + anger + pulse); ctx.lineTo(30, -35 + pulse);
            }
            ctx.fill();
            ctx.restore();
            
            ctx.restore();
        };
        draw();
    });
</script>

<style>
  #color-palette button {
      flex-shrink: 0;
  }
</style>
