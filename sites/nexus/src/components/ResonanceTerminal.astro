---
// ResonanceTerminal.astro
// Компонент для отображения последних событий из _SYNDICATE_EVENT.log

import fs from 'node:fs';
import path from 'node:path';

const LOG_FILE = path.join(process.cwd(), '../_SYNDICATE_EVENT.log');
let logs = [];

try {
  if (fs.existsSync(LOG_FILE)) {
    const content = fs.readFileSync(LOG_FILE, 'utf8');
    logs = content.trim().split('\n').reverse().slice(0, 8);
  } else {
    logs = ["[SYSTEM] // Ожидание первого импульса..."];
  }
} catch (e) {
  logs = [`[ERROR] // Ошибка чтения Ткани: ${e.message}`];
}

const colorizeEntry = (entry: string) => {
  if (entry.includes('STERILE_440HZ')) return 'text-cyber-primary font-black animate-pulse';
  if (entry.includes('SURGICAL_PRUNING')) return 'text-white font-black italic opacity-100';
  if (entry.includes('QUALITY_STABILIZATON')) return 'text-cyber-secondary font-black glow-text-secondary';
  if (entry.includes('BASIS_RESONANCE')) return 'text-cyber-primary opacity-80 italic';
  if (entry.includes('ERROR')) return 'text-red-500 animate-pulse';
  return 'text-cyber-muted italic opacity-60';
};
---

<div class="terminal-frame overflow-hidden bg-cyber-bg-light/95">
  <div class="t-tl terminal-corner"></div>
  <div class="t-tr terminal-corner"></div>
  <div class="t-bl terminal-corner"></div>
  <div class="t-br terminal-corner"></div>
  
  <div class="terminal-header flex justify-between items-center px-4 py-2 bg-cyber-secondary text-black">
    <span class="text-[10px] font-black uppercase tracking-widest italic">Live_Resonance_Log</span>
    <div class="flex gap-1.5 grayscale opacity-50">
      <div class="w-1.5 h-1.5 rounded-full bg-red-500"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-yellow-500"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
    </div>
  </div>
  <div class="terminal-body p-4 font-mono text-[9px] leading-relaxed max-h-48 overflow-y-auto custom-scrollbar">
    {logs.map((log) => (
      <div class="log-entry flex gap-3 mb-1.5 group border-b border-white/5 py-1">
        <span class="opacity-20 shrink-0 text-[8px] italic">RESO></span>
        <span class={colorizeEntry(log)}>{log}</span>
      </div>
    ))}
    <div class="cursor w-2 h-4 bg-cyber-secondary animate-pulse inline-block align-middle ml-1"></div>
  </div>
</div>

<style>
  .terminal-container {
    background: rgba(var(--color-cyber-bg-light-rgb, 8, 8, 26), 0.8);
    backdrop-filter: blur(12px);
    box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.5);
  }

  .terminal-body {
    position: relative;
  }

  .terminal-body::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%),
                linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
    background-size: 100% 2px, 3px 100%;
    pointer-events: none;
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--color-cyber-muted);
    border-radius: 10px;
  }
</style>
