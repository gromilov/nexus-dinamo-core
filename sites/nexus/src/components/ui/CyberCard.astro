---
interface Props {
  class?: string;
  variant?: 'default' | 'pink' | 'blue';
  title?: string;
}

const { class: className, variant = 'default', title } = Astro.props;

const variants = {
  default: "border-cyber-primary/20 hover:border-cyber-primary/60 shadow-xl bg-cyber-bg-light/80",
  pink: "border-cyber-secondary/30 hover:border-cyber-secondary/60 shadow-xl bg-cyber-bg-light/90 shadow-[inset_0_0_20px_rgba(197,160,89,0.05)]",
  blue: "border-cyber-primary/30 hover:border-cyber-primary/60 shadow-xl bg-black/40"
};
---

<div class:list={[
  "terminal-frame transition-all duration-500 overflow-hidden group/card",
  variants[variant],
  className
]}>
  <div class="t-tl terminal-corner"></div>
  <div class="t-tr terminal-corner"></div>
  <div class="t-bl terminal-corner"></div>
  <div class="t-br terminal-corner"></div>
  <div class="absolute top-0 right-0 p-4 opacity-10 group-hover/card:opacity-20 transition-opacity">
    <slot name="icon" />
  </div>

  {title && (
    <h3 class="text-[10px] uppercase text-cyber-secondary mb-4 tracking-[0.4em] font-black italic">{title}</h3>
  )}
  <div class="relative z-10">
    <slot />
  </div>
</div>

<style>
  .glass {
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    position: relative;
  }
  .glass::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--glass-noise);
    opacity: 0.1;
    pointer-events: none;
    z-index: -1;
  }
</style>
