---
// src/components/ui/DecryptText.astro
interface Props {
  text: string;
  className?: string;
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'p' | 'span' | 'div';
}

const { text, className = '', as: Tag = 'span' } = Astro.props;
---

<Tag class={`decrypt-text inline-block cursor-default ${className}`} data-value={text}>
  {text}
</Tag>

<script>
  // Cyber-Scramble effect
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*X";
  const elements = document.querySelectorAll('.decrypt-text');

  elements.forEach((el) => {
    let interval: number;

    el.addEventListener('mouseover', (e) => {
      const target = e.target as HTMLElement;
      let iteration = 0;
      
      clearInterval(interval);
      
      const originalText = target.dataset.value || "";

      interval = window.setInterval(() => {
        target.innerText = originalText
          .split("")
          .map((letter, index) => {
            if(index < iteration) {
              return originalText[index];
            }
            if(letter === ' ') return ' ';
            return letters[Math.floor(Math.random() * 41)];
          })
          .join("");
        
        // Decrypt faster or slower depending on length
        const step = originalText.length > 20 ? 1 : 1/3;
        if(iteration >= originalText.length){ 
          clearInterval(interval);
        }
        
        iteration += step;
      }, 30);
    });
  });
</script>

<style>
  .decrypt-text {
    transition: color 0.3s;
  }
  .decrypt-text:hover {
    color: var(--color-cyber-primary);
    text-shadow: 0 0 8px var(--color-cyber-primary);
  }
</style>
